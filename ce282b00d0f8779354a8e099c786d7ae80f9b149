      "writtenOn": "2026-04-24T04:52:56Z",
      "side": 1,
      "message": "Is there a reason we are choosing to use the word \"instance\" here, as opposed to \"package\"?",
      "range": {
        "startLine": 704,
        "startChar": 62,
        "endLine": 704,
        "endChar": 73
      },
      "revId": "ce282b00d0f8779354a8e099c786d7ae80f9b149",
