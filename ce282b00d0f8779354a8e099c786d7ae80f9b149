    {
      "unresolved": true,
      "key": {
        "uuid": "0e19562f_d01707ef",
        "filename": "designs/XXXX-go-plugins.md",
        "patchSetId": 1
      },
      "lineNbr": 704,
      "author": {
        "id": 1007275
      },
      "writtenOn": "2026-04-24T07:51:55Z",
      "side": 1,
      "message": "Because according to the CUE spec, that\u0027s the correct naming (see https://cuelang.org/docs/reference/spec/#modules-instances-and-packages).\n\nPersonally I\u0027m not that keen on the naming (informally, we say package and in fact there\u0027s no real \"thing\" that is a package), but I\u0027ve gone with the official naming for the sake of argument. Happy to use the word \"package\" throughout if you think that\u0027s better.",
      "parentUuid": "05d0f2eb_2d855d73",
      "range": {
        "startLine": 704,
        "startChar": 62,
        "endLine": 704,
        "endChar": 73
      },
      "revId": "ce282b00d0f8779354a8e099c786d7ae80f9b149",
